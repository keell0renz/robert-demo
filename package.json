{
  "name": "robert-demo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postgres:start": "node scripts/postgres-dev-server.mjs start",
    "postgres:stop": "node scripts/postgres-dev-server.mjs stop",
    "postgres:status": "node scripts/postgres-dev-server.mjs status",
    "postgres:restart": "node scripts/postgres-dev-server.mjs restart",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "db:reset": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/db-reset.mjs",
    "db:seed": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.1",
    "@ai-sdk/openai": "^4.0.2",
    "@ai-sdk/react": "^4.0.5",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@remixicon/react": "^4.9.0",
    "ai": "^7.0.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "eve": "^0.16.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@csstools/postcss-color-mix-function": "^4.0.5",
    "@csstools/postcss-oklab-function": "^5.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "supabase"
    ]
  }
}
